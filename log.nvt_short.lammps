# ---------------- Groups ----------------
group           caffeine molecule 1
24 atoms in group caffeine
group           water type 25 26
2400 atoms in group water

# ---------------- Constraints ----------------
# Assumed:
#   bond type 26 = O-H (water)
#   angle type 44 = H-O-H (water)
fix             fxShake water shake 1.0e-4 200 0 b 26 a 44
Finding SHAKE clusters ...
       0 = # of size 2 clusters
       0 = # of size 3 clusters
       0 = # of size 4 clusters
     800 = # of frozen angles
  find clusters CPU = 0.001 seconds

# ---------------- Initialization ----------------
reset_timestep  0
timestep        0.5

# Gentle initial velocity assignment
velocity        all create 150.0 4928459 rot yes dist gaussian mom yes

# ---------------- Output ----------------
thermo          100
thermo_style    custom step temp pe ke etotal press density vol
thermo_modify   flush yes

dump            d1 all custom 500 nvt_short.lammpstrj id mol type q x y z vx vy vz
dump_modify     d1 sort id

# ---------------- Stage 1: slow heating ----------------
fix             fxNVT1 all nvt temp 150.0 298.0 200.0
run             10000
