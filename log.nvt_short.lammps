# =========================================================
# Short conservative NVT for initial thermal accommodation
# System: caffeine + SPC/E water
# Starting point: minimized structure
# =========================================================

include         in.common
units real
atom_style full
boundary p p p

pair_style      lj/cut/coul/long 10.0 10.0
pair_modify     mix geometric tail no
bond_style      harmonic
angle_style     harmonic
dihedral_style  opls
improper_style  cvff
kspace_style    pppm 1.0e-4
special_bonds   lj/coul 0.0 0.0 0.5
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes
read_data       minimized_opls_spce.data
