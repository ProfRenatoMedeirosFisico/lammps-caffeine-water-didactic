LAMMPS (2 Aug 2023 - Update 3)
  using 1 OpenMP thread(s) per MPI task
# =========================================================
# NVT production — LONG run (500 000 steps / 250 ps)
# System: caffeine + SPC/E water
# Starting point: NPT-equilibrated structure (npt_eq_final.data)
#
# This script replaces in.nvt_prod_long and adds:
#   - MSD for water oxygens  (-> msd_waterO.dat)
#   - MSD for caffeine       (-> msd_caffeine.dat)
#   - Averaged thermo output (-> thermo_avg_prod_long.dat)
#
# Required for: items 1.1.1, 1.1.3, Fig. 6 (RBEF revision)
# =========================================================

# ---------------------------------------------------------
# 1. Common parameters (pair styles, kspace, bonds, etc.)
# ---------------------------------------------------------
include         in.common
units real
atom_style full
boundary p p p

pair_style      lj/cut/coul/long 10.0 10.0
pair_modify     mix geometric tail no
bond_style      harmonic
angle_style     harmonic
dihedral_style  opls
improper_style  cvff
kspace_style    pppm 1.0e-4
special_bonds   lj/coul 0.0 0.0 0.5
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

# ---------------------------------------------------------
# 2. Load NPT-equilibrated structure
# ---------------------------------------------------------
read_data       npt_eq_final.data
Reading data file ...
  orthogonal box = (0.46844179 0.49244279 0.44294179) to (29.530558 29.554559 29.505058)
  2 by 2 by 2 MPI processor grid
  reading atoms ...
  2424 atoms
  reading velocities ...
  2424 velocities
  scanning bonds ...
  2 = max bonds/atom
  scanning angles ...
  6 = max angles/atom
  scanning dihedrals ...
  7 = max dihedrals/atom
  scanning impropers ...
  4 = max impropers/atom
  reading bonds ...
  1625 bonds
  reading angles ...
  843 angles
  reading dihedrals ...
  54 dihedrals
  reading impropers ...
  14 impropers
Finding 1-2 1-3 1-4 neighbors ...
  special bond factors lj:    0        0        0.5     
  special bond factors coul:  0        0        0.5     
     4 = max # of 1-2 neighbors
     7 = max # of 1-3 neighbors
    16 = max # of 1-4 neighbors
    16 = max # of special neighbors
  special bonds CPU = 0.000 seconds
  read_data CPU = 0.020 seconds

# ---------------------------------------------------------
# 3. Atom groups
# ---------------------------------------------------------
group           caffeine  molecule 1
24 atoms in group caffeine
group           water     type 25 26
2400 atoms in group water
group           waterO    type 25
800 atoms in group waterO
group           waterH    type 26
1600 atoms in group waterH
group           caffO     type 13 14
2 atoms in group caffO
group           caffN     type 2 4 8 11
4 atoms in group caffN

# ---------------------------------------------------------
# 4. SHAKE constraints (SPC/E rigid geometry)
#    bond type 26 = O-H | angle type 44 = H-O-H
# ---------------------------------------------------------
fix             fxShake water shake 1.0e-4 200 0 b 26 a 44
Finding SHAKE clusters ...
       0 = # of size 2 clusters
       0 = # of size 3 clusters
       0 = # of size 4 clusters
     800 = # of frozen angles
  find clusters CPU = 0.000 seconds

# ---------------------------------------------------------
# 5. Time step and reset
# ---------------------------------------------------------
reset_timestep  0
timestep        0.5

# ---------------------------------------------------------
# 6. Thermostat — Nose-Hoover NVT (Tdamp = 200 fs)
# ---------------------------------------------------------
fix             fxNVT all nvt temp 298.0 298.0 200.0

# ---------------------------------------------------------
# 7. Thermodynamic output (every 100 steps = 0.05 ps)
# ---------------------------------------------------------
thermo          100
thermo_style    custom step temp pe ke etotal press density vol
thermo_modify   flush yes

# ---------------------------------------------------------
# 8. Trajectory dump (every 1000 steps = 0.5 ps)
# ---------------------------------------------------------
dump            d1 all custom 1000 nvt_prod_long.lammpstrj                 id mol type q x y z vx vy vz
dump_modify     d1 sort id

# ---------------------------------------------------------
# 9. Restart files (every 50 000 steps)
# ---------------------------------------------------------
restart         50000 nvt_prod_long.restart1 nvt_prod_long.restart2

# ---------------------------------------------------------
# 10. MSD — water oxygens
#     com yes = removes center-of-mass drift before computing MSD
#     Output: step  MSD_waterO (A^2)
#     Averaged over windows of 1000 steps (every 100 steps, 10 samples)
# ---------------------------------------------------------
compute         cMSDwatO waterO msd com yes
fix             fxMSDwatO waterO ave/time 100 10 1000                 c_cMSDwatO[4] file msd_waterO.dat title1 "# Step MSD_waterO(A^2)"

# ---------------------------------------------------------
# 11. MSD — caffeine (center of mass)
# ---------------------------------------------------------
compute         cMSDcaf caffeine msd com yes
fix             fxMSDcaf caffeine ave/time 100 10 1000                 c_cMSDcaf[4] file msd_caffeine.dat title1 "# Step MSD_caffeine(A^2)"

# ---------------------------------------------------------
# 12. Averaged thermodynamic variables
#     Smoothed over windows of 1000 steps for comparison tables
# ---------------------------------------------------------
variable        vTemp   equal temp
variable        vPress  equal press
variable        vDens   equal density
variable        vVol    equal vol
variable        vPE     equal pe
variable        vKE     equal ke
variable        vEtot   equal etotal

fix             fxAvg all ave/time 100 10 1000                 v_vTemp v_vPress v_vDens v_vPE v_vKE v_vEtot v_vVol                 file thermo_avg_prod_long.dat mode scalar

# ---------------------------------------------------------
# 13. Run: 500 000 steps = 250 ps
# ---------------------------------------------------------
run             1000000
