LAMMPS (2 Aug 2023 - Update 3)
  using 1 OpenMP thread(s) per MPI task
# =========================================================
# NVT direct protocol — CONTROLLED comparison (item 1.2.1)
# System: caffeine + SPC/E water
# Starting point: nvt_short_final.data
#   (output of the short NVT ramp 150->298 K)
#
# DESIGN: This script differs from the full protocol ONLY
# in the absence of the NPT equilibration step.
# ALL other parameters are IDENTICAL to the full protocol:
#   - Same Tdamp = 200 fs
#   - Same initial structure (post-NVT-short)
#   - Same timestep (0.5 fs)
#   - Same SHAKE settings
#   - Same run length (200 000 steps / 100 ps for comparison)
#
# Required for: item 1.2.1 (RBEF revision R1)
# =========================================================

include         in.common
units real
atom_style full
boundary p p p

pair_style      lj/cut/coul/long 10.0 10.0
pair_modify     mix geometric tail no
bond_style      harmonic
angle_style     harmonic
dihedral_style  opls
improper_style  cvff
kspace_style    pppm 1.0e-4
special_bonds   lj/coul 0.0 0.0 0.5
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes
read_data       nvt_short_final.data
